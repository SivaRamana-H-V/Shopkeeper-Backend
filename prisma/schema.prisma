// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum MemberRole {
  OWNER
  MEMBER
}

enum LedgerStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PARTIAL_PAID
  PAID
  CANCELLED
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
}

enum MessageType {
  SYSTEM_EVENT
  USER_MESSAGE
}

// ─────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  supabaseUserId   String   @unique @map("supabase_user_id")
  email            String   @unique
  name             String
  phone            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  memberships      ShopMember[]
  ledgerEntries    LedgerEntry[]    @relation("LedgerUser")
  createdEntries   LedgerEntry[]    @relation("LedgerCreatedBy")
  payments         Payment[]
  sentMessages     ChatMessage[]    @relation("MessageSender")

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// SHOPS
// ─────────────────────────────────────────────────────────────────

model Shop {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members       ShopMember[]
  ledgerEntries LedgerEntry[]
  payments      Payment[]
  chatMessages  ChatMessage[]

  @@map("shops")
}

// ─────────────────────────────────────────────────────────────────
// MEMBERSHIPS
// ─────────────────────────────────────────────────────────────────

model ShopMember {
  id       String     @id @default(uuid())
  userId   String     @map("user_id")
  shopId   String     @map("shop_id")
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now()) @map("joined_at")

  user User @relation(fields: [userId], references: [id])
  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([userId, shopId])
  @@map("shop_members")
}

// ─────────────────────────────────────────────────────────────────
// LEDGER
// ─────────────────────────────────────────────────────────────────

model LedgerEntry {
  id               String       @id @default(uuid())
  shopId           String       @map("shop_id")
  userId           String       @map("user_id")
  originalAmount   Decimal      @map("original_amount") @db.Decimal(12, 2)
  note             String?
  status           LedgerStatus @default(PENDING_APPROVAL)
  rejectionReason  String?      @map("rejection_reason")
  parentEntryId    String?      @map("parent_entry_id")
  createdBy        String       @map("created_by")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  shop        Shop          @relation(fields: [shopId], references: [id])
  user        User          @relation("LedgerUser", fields: [userId], references: [id])
  creator     User          @relation("LedgerCreatedBy", fields: [createdBy], references: [id])
  parentEntry LedgerEntry?  @relation("EntryCorrections", fields: [parentEntryId], references: [id])
  corrections LedgerEntry[] @relation("EntryCorrections")

  allocations  PaymentAllocation[]
  chatMessages ChatMessage[]       @relation("LedgerMessages")

  @@index([shopId, userId])
  @@index([shopId, status])
  @@map("ledger_entries")
}

// ─────────────────────────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────────────────────────

model Payment {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  shopId    String        @map("shop_id")
  amount    Decimal       @db.Decimal(12, 2)
  status    PaymentStatus @default(INITIATED)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id])
  shop         Shop                @relation(fields: [shopId], references: [id])
  allocations  PaymentAllocation[]
  chatMessages ChatMessage[]       @relation("PaymentMessages")

  @@index([userId, shopId])
  @@map("payments")
}

model PaymentAllocation {
  id              String  @id @default(uuid())
  paymentId       String  @map("payment_id")
  ledgerEntryId   String  @map("ledger_entry_id")
  allocatedAmount Decimal @map("allocated_amount") @db.Decimal(12, 2)

  payment     Payment     @relation(fields: [paymentId], references: [id])
  ledgerEntry LedgerEntry @relation(fields: [ledgerEntryId], references: [id])

  @@index([paymentId])
  @@index([ledgerEntryId])
  @@map("payment_allocations")
}

// ─────────────────────────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────────────────────────

model ChatMessage {
  id               String      @id @default(uuid())
  shopId           String      @map("shop_id")
  senderId         String?     @map("sender_id")
  messageType      MessageType @map("message_type")
  relatedLedgerId  String?     @map("related_ledger_id")
  relatedPaymentId String?     @map("related_payment_id")
  content          String
  createdAt        DateTime    @default(now()) @map("created_at")

  shop           Shop         @relation(fields: [shopId], references: [id])
  sender         User?        @relation("MessageSender", fields: [senderId], references: [id])
  relatedLedger  LedgerEntry? @relation("LedgerMessages", fields: [relatedLedgerId], references: [id])
  relatedPayment Payment?     @relation("PaymentMessages", fields: [relatedPaymentId], references: [id])

  @@index([shopId, createdAt])
  @@map("chat_messages")
}
